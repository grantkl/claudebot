# Required
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
ALLOWED_USER_IDS=U12345678,U87654321

# Authentication (one of these is required)
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Optional
CLAUDE_MODEL=sonnet
CLAUDE_SYSTEM_PROMPT=You are a helpful AI assistant available through Slack.
SESSION_TTL_SECONDS=3600
LOG_LEVEL=INFO

# MCP Server Integrations (requires running on host, not Docker)
ENABLE_MCP=false
HOMEKIT_PAIRING_FILE=
