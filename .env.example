# Required
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Authentication (one of these is required)
# In Docker, the auth-proxy sidecar injects credentials into API requests.
# The real token stays in .env; the agent only sees a dummy placeholder.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Optional
CLAUDE_MODEL=sonnet
CLAUDE_SYSTEM_PROMPT=You are a helpful AI assistant available through Slack.
SESSION_TTL_SECONDS=3600
LOG_LEVEL=INFO
AUTHORIZED_USER_IDS=U12345678,U87654321
RATE_LIMIT_MESSAGES=0
RATE_LIMIT_WINDOW_SECONDS=3600

# MCP Server Integrations (supported in Docker with direct IP config)
ENABLE_MCP=false
HOMEKIT_PAIRING_FILE=
# HomeClaw HTTP bridge URL (e.g., http://host.docker.internal:9876)
HOMECLAW_MCP_URL=
# Comma-separated Sonos speaker IPs for Docker mode (e.g., 192.168.1.10,192.168.1.11)
SONOS_SPEAKER_IPS=

# Superuser tier (comma-separated Slack user IDs with elevated privileges like Gmail)
SUPERUSER_IDS=
# Gmail OAuth credentials and token file paths (superuser-only)
GMAIL_CREDENTIALS_FILE=
GMAIL_TOKEN_FILE=

# Autonomous Task Scheduler
SCHEDULER_ENABLED=false
SCHEDULER_TASKS_FILE=config/tasks.yaml
SCHEDULER_STATE_FILE=data/scheduler_state.json
SCHEDULER_CONCURRENCY=3
SCHEDULER_TIMEZONE=US/Pacific

# Flights (Amadeus API — https://developers.amadeus.com/)
FLIGHTS_ENABLED=false
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Flight price watch data file
FLIGHT_WATCH_FILE=data/flight_watches.json

# Award flight search (seats.aero Partner API)
SEATS_AERO_API_KEY=

# Stocks (yfinance — no API key required)
STOCKS_ENABLED=false

# Web Search (Brave Search API — https://brave.com/search/api/)
BRAVE_API_KEY=

# Playwright browser automation
PLAYWRIGHT_ENABLED=false
